# Sao chép:  cp env.example .env
# Next.js đọc .env, .env.local, … — Prisma CLI đọc qua prisma.config.ts (dotenv).

# --- Bắt buộc ---

# PostgreSQL (app + Prisma). Khớp POSTGRES_* bên dưới nếu dùng Docker Compose local.
DATABASE_URL=postgresql://debt:debt_dev_secret@127.0.0.1:5432/debt_done_right

# Mật khẩu cho mọi thao tác ghi dữ liệu trên UI
DEBT_APP_PASSWORD=changeme

# --- Tuỳ chọn (app) ---

# Chỉ định tenant cố định (UUID Organization). Bỏ trống = dùng org đầu tiên trong DB.
# TENANT_ID=

# TLS chứng chỉ tự ký / proxy: false | 0 | no
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Google Analytics 4 — Measurement ID (Admin → Data streams → Web). Bỏ trống = không tải GA.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Tuỳ chọn (Prisma migrate dev — shadow DB) ---

# Chỉ cần khi dùng `prisma migrate dev` và muốn shadow khác URL chính.
# DIRECT_DATABASE_URL=

# --- Docker Compose (biến này được docker compose đọc từ file .env cùng thư mục docker-compose.yml) ---

POSTGRES_USER=debt
POSTGRES_PASSWORD=debt_dev_secret
POSTGRES_DB=debt_done_right
POSTGRES_PUBLISH_PORT=5432
